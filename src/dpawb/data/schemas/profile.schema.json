{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "profile_id",
    "label",
    "profile_version",
    "comparison_scope_label",
    "models"
  ],
  "properties": {
    "profile_id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "profile_version": {
      "type": "string",
      "minLength": 1
    },
    "comparison_scope_label": {
      "type": "string",
      "minLength": 1
    },
    "models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "model_id",
          "source"
        ],
        "properties": {
          "model_id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "model_version": {
            "type": "string"
          },
          "source": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
