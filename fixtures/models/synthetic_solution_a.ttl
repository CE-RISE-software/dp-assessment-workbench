@prefix ex: <https://example.org/a/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:PassportShape
  a sh:NodeShape ;
  sh:targetClass ex:Passport ;
  sh:property ex:passport_identifier_property ;
  sh:property ex:version_note_property .

ex:passport_identifier_property
  a sh:PropertyShape ;
  sh:path ex:passportIdentifier ;
  sh:datatype xsd:string ;
  sh:minCount 1 ;
  sh:maxCount 1 .

ex:version_note_property
  a sh:PropertyShape ;
  sh:path ex:versionNote .
